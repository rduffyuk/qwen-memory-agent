# Qwen Cloud / DashScope (OpenAI-compatible). Copy to .env and fill in.
# .env is gitignored — NEVER commit the real key.
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional runtime knobs.
MEMORY_PERSIST_PATH=memory.json
SUPERSEDE_THRESHOLD=0.9
